# =============================================================================
# HumanAgentCollab — environment template
# Copy to `.env` at the project root (same folder as docker-compose.yml).
# Docker Compose also reads this file for variable substitution.
# =============================================================================

# --- Flask / security ---
FLASK_SECRET_KEY=change-me-in-production
# SECRET_KEY=   # optional alias read by app.py

# --- LLM (agents) — see backend/agent/README_LLM.md ---
# openai | azure | claude | mock
LLM_PROVIDER=mock

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Azure OpenAI (when LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Text-to-speech deployment (agent voice messages when Communication Media includes Audio).
# Must be a speech/TTS deployment in Azure; not the same as AZURE_OPENAI_DEPLOYMENT unless you use a TTS-only deployment name there.
AZURE_TTS_DEPLOYMENT=

# Anthropic (when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# --- Audio transcription (/api/transcribe) — optional ---
# Whisper input language (ISO-639-1, e.g. en). Defaults to en if unset.
TRANSCRIBE_LANGUAGE=en
# Azure Whisper-style deployment or OpenAI key
AZURE_WHISPER_DEPLOYMENT=
# AZURE_DEPLOYMENT_ID=
# OPENAI_API_KEY=   # reused if set above

# --- Agent TTS (voice messages from AI when Communication Media includes Audio) ---
# Provider: auto (default) | azure | openai
# auto: use Azure if AZURE_OPENAI_ENDPOINT + AZURE_OPENAI_API_KEY + AZURE_TTS_DEPLOYMENT are set; else OpenAI if OPENAI_API_KEY is set.
# If both are configured, auto tries Azure first, then falls back to OpenAI on failure.
AGENT_TTS_PROVIDER=auto
# Voice name (OpenAI / Azure OpenAI compatible set, e.g. alloy, echo, fable, onyx, nova, shimmer)
AGENT_TTS_VOICE=alloy
# OpenAI-only model id (ignored for Azure; Azure uses AZURE_TTS_DEPLOYMENT as the deployment name)
AGENT_TTS_MODEL=tts-1

# --- Realtime API (WebRTC when meeting_room + AI in session) ---
# Provider: auto | openai | azure — controls POST /api/realtime/calls proxy target.
REALTIME_PROVIDER=auto
# Optional: force session.model for both providers (overrides AZURE_REALTIME_DEPLOYMENT / OPENAI_REALTIME_MODEL).
# REALTIME_SESSION_MODEL=gpt-realtime-1.5
# OpenAI (api.openai.com) only — ignored for Azure if AZURE_REALTIME_DEPLOYMENT is set
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
OPENAI_REALTIME_VOICE=marin
# Meeting room live captions: model for realtime input audio transcription (OpenAI/Azure Realtime).
# REALTIME_INPUT_TRANSCRIPTION_MODEL=whisper-1
# Azure Realtime: MUST match the deployment *name* in Azure (e.g. gpt-realtime-1.5), not the OpenAI catalog id.
# If unset, session.model falls back to OPENAI_REALTIME_MODEL and Azure will reject it.
AZURE_REALTIME_DEPLOYMENT=
# Azure output voice (GA docs): alloy, ash, ballad, coral, echo, sage, shimmer, verse — not marin.
# AZURE_REALTIME_VOICE=alloy
# Set to 1 to use semantic_vad instead of server_vad (may behave differently on Azure).
# AZURE_REALTIME_SEMANTIC_VAD=0
# Query string for POST .../realtime/calls (default webrtcfilter=on for browser WebRTC)
# AZURE_REALTIME_CALLS_QUERY=webrtcfilter=on
# If client_secrets returns 500, try (see Azure docs for your region): AZURE_REALTIME_CLIENT_SECRETS_API_VERSION=2025-04-01-preview
# AZURE_REALTIME_CLIENT_SECRETS_API_VERSION=
# Larger prompt in client_secrets (default is a short stub + session.update for full tools/instructions)
# AZURE_REALTIME_CLIENT_SECRETS_FULL_PROMPT=0
# AZURE_REALTIME_CLIENT_SECRETS_FULL_AUDIO=0
# Meeting room: 1 = app-managed turns (client dispatcher → one response.create with audio per user utterance). 0 = legacy per-agent VAD + client moderation.
# REALTIME_ORCHESTRATED_FLOOR=1

# --- PostgreSQL ---
# The app reads DATABASE_URL first; if it is empty, it uses PGHOST / PGUSER / PGPASSWORD / PGPORT / PGDATABASE.
# Use EITHER a full URL OR the discrete vars — do not rely on both at once unless you know which wins (URL wins).

# Option A — single connection URL (Docker local Postgres or RDS)
# Local Docker (password must match POSTGRES_PASSWORD):
# DATABASE_URL=postgresql://postgres:changeme@postgres:5432/humanagent
# AWS RDS example:
# DATABASE_URL=postgresql://myuser:mypassword@mydb.xxxx.us-east-1.rds.amazonaws.com:5432/mydbname

# Option B — discrete fields (typical for RDS). Omit DATABASE_URL entirely, or comment it out.
PGUSER=
PGPASSWORD=
PGHOST=
# RDS endpoint example: mydb.xxxxxxxx.us-east-1.rds.amazonaws.com (host only — no https://, no port here)
PGPORT=5432
PGDATABASE=

# All app tables live in this schema (isolated from other systems sharing the same database)
PGSCHEMA=humanagent_collab
# DATABASE_SCHEMA=humanagent_collab   # alias for PGSCHEMA

# --- Docker Compose: bundled Postgres (see docker-compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=humanagent
POSTGRES_PORT=5432

# --- Ports (optional overrides for compose) ---
BACKEND_PORT=5000
FRONTEND_PORT=8080

# --- AWS S3 (annotation screenshots, post-annotation browser PUT, etc.) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
# For browser uploads to S3, configure bucket CORS (PUT + GET for presigned URLs).

# --- AWS MTurk ---
# Keep region unified with AWS_REGION (Scheme A).
# Environment controls which MTurk endpoint backend uses.
# sandbox -> https://mturk-requester-sandbox.us-east-1.amazonaws.com
# production -> https://mturk-requester.us-east-1.amazonaws.com
MTURK_ENVIRONMENT=sandbox
