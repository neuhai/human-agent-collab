# =============================================================================
# HumanAgentCollab — environment template
# Copy to `.env` at the project root (same folder as docker-compose.yml).
# Docker Compose also reads this file for variable substitution.
# =============================================================================

# --- Flask / security ---
FLASK_SECRET_KEY=change-me-in-production
# SECRET_KEY=   # optional alias read by app.py

# --- LLM (agents) — see backend/agent/README_LLM.md ---
# openai | azure | claude | mock
LLM_PROVIDER=mock

# OpenAI (when LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Azure OpenAI (when LLM_PROVIDER=azure)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Anthropic (when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=

# --- Audio transcription (/api/transcribe) — optional ---
# Whisper input language (ISO-639-1, e.g. en). Defaults to en if unset.
TRANSCRIBE_LANGUAGE=en
# Azure Whisper-style deployment or OpenAI key
AZURE_WHISPER_DEPLOYMENT=
# AZURE_DEPLOYMENT_ID=
# OPENAI_API_KEY=   # reused if set above

# --- PostgreSQL ---
# The app reads DATABASE_URL first; if it is empty, it uses PGHOST / PGUSER / PGPASSWORD / PGPORT / PGDATABASE.
# Use EITHER a full URL OR the discrete vars — do not rely on both at once unless you know which wins (URL wins).

# Option A — single connection URL (Docker local Postgres or RDS)
# Local Docker (password must match POSTGRES_PASSWORD):
# DATABASE_URL=postgresql://postgres:changeme@postgres:5432/humanagent
# AWS RDS example:
# DATABASE_URL=postgresql://myuser:mypassword@mydb.xxxx.us-east-1.rds.amazonaws.com:5432/mydbname

# Option B — discrete fields (typical for RDS). Omit DATABASE_URL entirely, or comment it out.
PGUSER=
PGPASSWORD=
PGHOST=
# RDS endpoint example: mydb.xxxxxxxx.us-east-1.rds.amazonaws.com (host only — no https://, no port here)
PGPORT=5432
PGDATABASE=

# All app tables live in this schema (isolated from other systems sharing the same database)
PGSCHEMA=humanagent_collab
# DATABASE_SCHEMA=humanagent_collab   # alias for PGSCHEMA

# --- Docker Compose: bundled Postgres (see docker-compose.yml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=humanagent
POSTGRES_PORT=5432

# --- Ports (optional overrides for compose) ---
BACKEND_PORT=5000
FRONTEND_PORT=8080

# --- AWS S3 (annotation screenshots, post-annotation browser PUT, etc.) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=
# For browser uploads to S3, configure bucket CORS (PUT + GET for presigned URLs).

# --- AWS MTurk ---
# Keep region unified with AWS_REGION (Scheme A).
# Environment controls which MTurk endpoint backend uses.
# sandbox -> https://mturk-requester-sandbox.us-east-1.amazonaws.com
# production -> https://mturk-requester.us-east-1.amazonaws.com
MTURK_ENVIRONMENT=sandbox
